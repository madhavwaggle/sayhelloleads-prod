# ============================================
# ReplyFast — Environment Variables
# Copy this to .env.local for local dev
# Add ALL of these to Vercel → Settings → Environment Variables
# ============================================

# --- REQUIRED ---
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# NextAuth secret — run: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here
# Your deployed URL (or http://localhost:3000 for local dev)
NEXTAUTH_URL=https://your-app.vercel.app

# --- PERSISTENCE (Vercel KV / Redis) ---
# Create at: Vercel Dashboard → Storage → Create KV Database
# Then copy the values from the KV dashboard
KV_URL=redis://...
KV_REST_API_URL=https://...
KV_REST_API_TOKEN=...
KV_REST_API_READ_ONLY_TOKEN=...

# --- OPTIONAL: SMS via Twilio ---
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+15135550100

# --- OPTIONAL: Email via Postmark ---
# Get from: https://postmarkapp.com → Server → API Tokens
POSTMARK_SERVER_TOKEN=...
# The inbound email address Postmark gives you (for Zillow/Homes.com lead forwarding)
POSTMARK_INBOUND_ADDRESS=xyz@inbound.postmarkapp.com

# --- AGENT SETTINGS ---
# Where to send hot lead alerts
AGENT_EMAIL=agent@youremail.com
AGENT_NAME=Your Name

# --- AUTH: Simple credentials login ---
# SHA-256 hash of your password (or use magic link email)
# Generate at: https://emn178.github.io/online-tools/sha256.html
ADMIN_EMAIL=admin@youragency.com
ADMIN_PASSWORD_HASH=your-bcrypt-hash

# --- OPTIONAL: Email magic link (nodemailer / Gmail) ---
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=you@gmail.com
EMAIL_SERVER_PASSWORD=your-app-password
EMAIL_FROM=ReplyFast <you@gmail.com>
