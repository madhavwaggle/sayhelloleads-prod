# ============================================================
# Say Hello Leads — Owner Environment Variables
# Add these to Vercel → Settings → Environment Variables
#
# AGENTS never see or touch these. They set up their own
# Twilio number and email forwarding from inside the app.
# ============================================================

# ── REQUIRED ─────────────────────────────────────────────────
NEXTAUTH_SECRET=your-random-secret-here    # openssl rand -base64 32
NEXTAUTH_URL=https://www.sayhelloleads.com # http://localhost:3000 for local

# ── DATABASE — Upstash Redis ─────────────────────────────────
# Create at: vercel.com → Storage → KV → Create
KV_REST_API_URL=https://YOUR-DB.upstash.io
KV_REST_API_TOKEN=YOUR-TOKEN-HERE

# ── AI — YOUR Anthropic key (included in agent subscriptions) ─
# All agent AI responses and lead scoring run through this key.
# Get it at: platform.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── EMAIL ALERTS — YOUR Resend key (included in subscriptions) ─
# Sends lead alert emails to agents when new leads come in.
# Get it at: resend.com → API Keys (free up to 3,000/mo)
RESEND_API_KEY=re_...

# ── OPTIONAL FALLBACKS ───────────────────────────────────────
# Only needed if you want a shared Twilio number or Postmark
# for agents who haven't set their own up yet.
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+15135550100
POSTMARK_SERVER_TOKEN=...
EMAIL_FROM=Say Hello Leads <noreply@sayhelloleads.com>
WEBHOOK_SECRET=your-random-secret-here

# ── GOOGLE PLACES — address autocomplete ─────────────────────
# Used for property address autofill on agent pages and demo.
# Must be prefixed NEXT_PUBLIC_ so it's available in the browser.
# Get it at: console.cloud.google.com → APIs → Places API
# IMPORTANT: Restrict to HTTP referrers: sayhelloleads.com/*
NEXT_PUBLIC_GOOGLE_PLACES_KEY=AIza...
