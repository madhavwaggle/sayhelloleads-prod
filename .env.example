# ============================================
# ReplyFast — Environment Variables
# Copy this file to .env.local for local dev
# Add ALL of these to Vercel → Settings → Environment Variables
# ============================================

# ── REQUIRED ────────────────────────────────────────────────────────────────

# Anthropic API key — https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# NextAuth secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here

# Your deployed Vercel URL (use http://localhost:3000 for local dev)
NEXTAUTH_URL=https://your-app.vercel.app

# ── DATABASE (Upstash Redis) ─────────────────────────────────────────────────
# Vercel → your project → Storage → Create Database → Upstash for Redis
# Vercel injects these automatically after creation — just verify they exist
KV_REST_API_URL=https://YOUR-DB.upstash.io
KV_REST_API_TOKEN=YOUR-TOKEN-HERE

# ── NOTIFICATIONS (Resend) ───────────────────────────────────────────────────
# Free tier: 3,000 emails/month — no domain needed to start
# Sign up at https://resend.com → API Keys → Create Key
RESEND_API_KEY=re_...

# ── SMS (Twilio) ─────────────────────────────────────────────────────────────
# One shared number for all pilot agents (~$1/month)
# https://console.twilio.com → Phone Numbers → Buy a Number
# Set webhook URL to: https://your-app.vercel.app/api/inbound-sms
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+15135550100

# ── AGENT ROUTING ────────────────────────────────────────────────────────────
# Used by /api/inbound-sms and /api/new-lead to route leads to the right agent
# How to find your ID: register your account → Upstash Console →
# Data Browser → search "users:index" → copy the UUID
DEFAULT_AGENT_ID=your-user-uuid-here

# ── EMAIL TO LEADS (Postmark) ────────────────────────────────────────────────
# Optional — only needed to email AI responses back to leads
# https://postmarkapp.com → Server → API Tokens
POSTMARK_SERVER_TOKEN=...
POSTMARK_INBOUND_ADDRESS=xyz@inbound.postmarkapp.com
EMAIL_FROM=ReplyFast <noreply@yourdomain.com>

# ── WEBHOOK SECURITY ─────────────────────────────────────────────────────────
# Optional shared secret to protect the /api/new-lead public endpoint
# Pass as header: x-webhook-secret: your-secret
WEBHOOK_SECRET=your-random-secret-here

# ── FALLBACK AGENT INFO ───────────────────────────────────────────────────────
# Used in AI prompts if agent profile not found in DB
AGENT_NAME=Your Name
AGENT_EMAIL=you@yourrealty.com
